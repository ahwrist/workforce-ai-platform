# ──────────────────────────────────────────────────────────────────
# WorkforceAI Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────

# ── LLM APIs ──────────────────────────────────────────────────────

# Anthropic Claude API (required for Synthesizer, Taxonomist, Interviewer)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (required for text-embedding-3-small)
OPENAI_API_KEY=sk-...

# ── Database ───────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/workforce_ai

# Qdrant vector database
QDRANT_URL=http://qdrant:6333

# Redis (Celery broker + cache)
REDIS_URL=redis://redis:6379/0

# ── Auth ───────────────────────────────────────────────────────────

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# NextAuth.js URL (set to your domain in production)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional, for Google sign-in in V2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret for API auth (generate with: openssl rand -base64 32)
SECRET_KEY=

# ── Scraping ───────────────────────────────────────────────────────

# Optional: Rotating proxy URL for high-volume scraping
# Format: http://user:pass@proxy-host:port
# Leave empty to scrape without a proxy (acceptable for Greenhouse/Lever)
SCRAPER_PROXY_URL=

# Delay between requests to the same domain (seconds)
SCRAPER_DELAY_SECONDS=3

# Admin API key for protected pipeline trigger endpoints
ADMIN_API_KEY=

# ── Email (V2+) ────────────────────────────────────────────────────

# Resend API key for transactional email (alerts, welcome sequences)
RESEND_API_KEY=

# From address for outbound emails
EMAIL_FROM=noreply@yourdomain.com

# ── Feature Flags ──────────────────────────────────────────────────

# Set to "true" to enable user registration (disable during early access)
ENABLE_REGISTRATION=false

# Set to "true" to enable the survey agent (can disable for maintenance)
ENABLE_SURVEY=true

# ── Monitoring (V2+) ───────────────────────────────────────────────

SENTRY_DSN=
LOG_LEVEL=INFO

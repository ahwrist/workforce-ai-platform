# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
SECRET_KEY=changeme_in_production_generate_with_openssl_rand_hex_32
NEXTAUTH_SECRET=changeme_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# LLM APIs
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...  # Used for text-embedding-3-small

# ─────────────────────────────────────────────
# Databases (Docker Compose defaults)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/workforce_ai
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# Scraping
# ─────────────────────────────────────────────
SCRAPER_PROXY_URL=
SCRAPER_DELAY_SECONDS=3

# ─────────────────────────────────────────────
# Pipeline Agent Model Config
# ─────────────────────────────────────────────
SYNTHESIZER_MODEL=claude-haiku-4-5-20251001
TAXONOMIST_MODEL=claude-haiku-4-5-20251001
INTERVIEWER_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────
ADMIN_API_KEY=changeme_admin_key
